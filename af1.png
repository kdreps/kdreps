  <!-- EXPORT MODAL -->
  <div id="if-export-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:9997;align-items:center;justify-content:center;padding:20px;">
    <div style="background:var(--bg2);border:1px solid var(--accent);border-radius:16px;padding:28px;max-width:680px;width:100%;max-height:82vh;display:flex;flex-direction:column;gap:16px;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--accent);">EKSPORT DO baza.js</div>
        <button onclick="document.getElementById('if-export-modal').style.display='none'" style="background:none;border:none;color:var(--text3);font-size:22px;cursor:pointer;line-height:1;">✕</button>
      </div>
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);line-height:1.7;">Skopiuj kod i wklej go na dole tablicy w <code style="color:var(--accent)">baza.js</code> — przed ostatnim <code style="color:var(--accent)">];</code></div>
      <textarea id="if-export-text" readonly style="flex:1;min-height:280px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--accent);font-family:'DM Mono',monospace;font-size:11px;padding:16px;resize:none;outline:none;"></textarea>
      <button onclick="ifCopyExport()" style="padding:14px;background:var(--accent);color:#000;font-family:'DM Mono',monospace;font-size:12px;font-weight:500;letter-spacing:2px;text-transform:uppercase;border:none;border-radius:8px;cursor:pointer;">📋 KOPIUJ DO SCHOWKA</button>
    </div>
  </div>

  <script src="baza.js?v=20260406_2"></script>
  <script>
    let _lastCatPage = 'buty';

    function renderProducts() {
      if (typeof KAKOBUY_DB === 'undefined') return;

      const grids = {};
      document.querySelectorAll('.product-grid[id^="grid-"]').forEach(grid => {
        let cat = grid.id.replace('grid-', '');
        grids[cat] = grid;
        grid.innerHTML = '';
      });

      KAKOBUY_DB.forEach((item, idx) => {
        let cat = item.category;
        if (!grids[cat]) return;

        let imgHTML = item.image
          ? `<img src="${item.image}" alt="${item.name}" loading="lazy">`
          : `<div class="no-img-placeholder">🛍️</div>`;

        let card = document.createElement('div');
        card.className = 'product-card';
        card.setAttribute('onclick', `openProduct(${idx}, '${cat}')`);

        card.innerHTML = `
            <div class="product-img-wrap">${imgHTML}</div>
            <div class="product-card-arrow">→</div>
            <div class="product-info">
                <div class="product-title">${item.name}</div>
                <div class="product-price">
                    <span class="pln">${item.pricePLN ? item.pricePLN + ' zł' : '—'}</span>
                    <span class="cny">${item.priceCNY ? '¥' + item.priceCNY : ''}</span>
                </div>
                <div class="product-tags">
                    ${item.quality ? `<span class="tag-batch">${item.quality}</span>` : ''}
                </div>
            </div>
        `;
        grids[cat].appendChild(card);
      });
    }

    function openProduct(idx, fromCat) {
      const item = KAKOBUY_DB[idx];
      if (!item) return;
      _lastCatPage = fromCat || item.category;

      // Category label
      const catNames = {
        'buty': 'OBUWIE', 'koszulki-bluzy': 'ODZIEŻ', 'koszulki-pilkarskie': 'SPORT',
        'spodenki': 'ODZIEŻ', 'spodnie': 'ODZIEŻ', 'sety': 'ODZIEŻ', 'skarpetki': 'AKCESORIA',
        'majtki': 'BIELIZNA', 'paski': 'AKCESORIA', 'portfele': 'AKCESORIA',
        'plecaki': 'AKCESORIA', 'czapki': 'AKCESORIA', 'kurtki': 'ODZIEŻ', 'perfumy': 'KOSMETYKI'
      };
      document.getElementById('pd-category').textContent = catNames[item.category] || item.category.toUpperCase();

      // Name
      document.getElementById('pd-name').textContent = item.name;

      // Prices
      document.getElementById('pd-price-pln').textContent = item.pricePLN ? item.pricePLN + ' zł' : '—';
      document.getElementById('pd-price-cny').textContent = item.priceCNY ? '¥ ' + item.priceCNY : '';

      // Image
      const frame = document.getElementById('pd-img-frame');
      if (item.image) {
        frame.innerHTML = `<img src="${item.image}" alt="${item.name}" style="width:100%;height:100%;object-fit:contain;padding:32px;">`;
      } else {
        const icons = { 'buty': '👟', 'koszulki-bluzy': '👕', 'koszulki-pilkarskie': '⚽', 'spodenki': '🩳', 'spodnie': '👖', 'sety': '👔', 'skarpetki': '🧦', 'majtki': '🩲', 'paski': '🥋', 'portfele': '👛', 'plecaki': '🎒', 'czapki': '🧢', 'kurtki': '🧥', 'perfumy': '💧' };
        frame.innerHTML = `<div class="pd-img-placeholder">${icons[item.category] || '🛍️'}</div>`;
      }

      // Badges
      const badges = document.getElementById('pd-badges');
      badges.innerHTML = '';
      if (item.quality) badges.innerHTML += `<div class="pd-badge">JAKOŚĆ: <span>${item.quality}</span></div>`;
      if (item.priceCNY) badges.innerHTML += `<div class="pd-badge">CENA CNY: <span>¥${item.priceCNY}</span></div>`;

      // Buy button
      const buyArea = document.getElementById('pd-buy-area');
      if (item.link && item.link !== '#') {
        buyArea.innerHTML = `<a href="${item.link}" target="_blank" class="pd-buy-btn">🛒 KUP TERAZ</a>`;
      } else {
        buyArea.innerHTML = `<div class="pd-no-link">🔗 Link niedostępny – dodaj go w baza.js</div>`;
      }

      // Navigate
      goTo('product');
    }

    function closePD() {
      goTo(_lastCatPage);
    }

    document.addEventListener("DOMContentLoaded", () => { renderProducts(); checkApiStatus(); });

    /* NAVIGATION */
    function goTo(name) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById('page-' + name).classList.add('active');
      window.scrollTo(0, 0);
      if (name === 'item-finder') checkApiStatus();
    }
    function goHome() {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById('page-home').classList.add('active');
      window.scrollTo(0, 0);
    }

    /* HAMBURGER */
    function toggleMenu() {
      document.getElementById('hamburger').classList.toggle('open');
      document.getElementById('mobileMenu').classList.toggle('open');
    }
    function closeMenu() {
      document.getElementById('hamburger').classList.remove('open');
      document.getElementById('mobileMenu').classList.remove('open');
    }

    /* SEARCH - INTELLIGENT PRODUCT SEARCH */
    const CAT_NAMES = {
      'buty': 'Buty', 'koszulki-bluzy': 'Koszulki & Bluzy', 'koszulki-pilkarskie': 'Koszulki Piłkarskie',
      'spodenki': 'Spodenki', 'spodnie': 'Spodnie', 'sety': 'Sety', 'skarpetki': 'Skarpetki',
      'majtki': 'Majtki', 'paski': 'Paski', 'portfele': 'Portfele',
      'plecaki': 'Plecaki', 'czapki': 'Czapki', 'kurtki': 'Kurtki', 'perfumy': 'Perfumy'
    };
    const CAT_ICONS = {
      'buty': '👟', 'koszulki-bluzy': '👕', 'koszulki-pilkarskie': '⚽', 'spodenki': '🩳',
      'spodnie': '👖', 'sety': '👔', 'skarpetki': '🧦', 'majtki': '🩲', 'paski': '🥋',
      'portfele': '👛', 'plecaki': '🎒', 'czapki': '🧢', 'kurtki': '🧥', 'perfumy': '💧'
    };

    const norm = s => (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();

    function scoreProduct(item, nq, words) {
      const n = norm(item.name);
      const cat = norm(CAT_NAMES[item.category] || item.category);
      let score = 0;
      // Exact match gets highest score
      if (n === nq) score += 100;
      // Starts with query
      if (n.startsWith(nq)) score += 50;
      // Contains full query as substring
      if (n.includes(nq)) score += 30;
      // Category match
      if (cat.includes(nq)) score += 20;
      // Individual word matches (fuzzy)
      words.forEach(w => {
        if (w.length < 2) return;
        if (n.includes(w)) score += 15;
        if (cat.includes(w)) score += 5;
      });
      return score;
    }

    function handleSearch(val) {
      const q = val.trim();
      const box = document.getElementById('searchResults');
      if (q.length < 2) { box.classList.remove('visible'); box.innerHTML = ''; return; }

      const nq = norm(q);
      const words = nq.split(/\s+/).filter(w => w.length >= 2);

      if (typeof KAKOBUY_DB === 'undefined') return;

      // Score and filter products
      const results = KAKOBUY_DB
        .map((item, idx) => ({ item, idx, score: scoreProduct(item, nq, words) }))
        .filter(r => r.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 12);

      if (!results.length) {
        box.innerHTML = `<div class="search-result-item"><div class="sri-text"><div class="sri-name" style="color:var(--text3)">Brak wyników dla &ldquo;${q}&rdquo;</div><div class="sri-sub">Spróbuj innej nazwy lub marki</div></div></div>`;
      } else {
        const header = `<div class="search-section-header">📦 PRODUKTY</div>`;
        const items = results.map(({ item, idx }) => {
          const thumb = item.image
            ? `<img src="${item.image}" alt="${item.name}">`
            : `<div class="sri-thumb-emoji">${CAT_ICONS[item.category] || '🛍️'}</div>`;
          const price = item.pricePLN ? `<span class="sri-price">${item.pricePLN} zł</span>` : '';
          const catLabel = CAT_NAMES[item.category] || item.category;
          return `
          <div class="search-result-item" onclick="openProduct(${idx}, '${item.category}'); clearSearch();">
            <div class="sri-thumb">${thumb}</div>
            <div class="sri-text">
              <div class="sri-name">${item.name}</div>
              <div class="sri-sub">${price}<span class="sri-cat">${catLabel}</span></div>
            </div>
            <div class="sri-arrow">→</div>
          </div>`;
        }).join('');
        const footer = results.length === 12
          ? `<div class="search-result-count">⚡ Wyświetlono 12 / więcej – Wpisz dokładniejszą frazę</div>` : '';
        box.innerHTML = header + items + footer;
      }
      box.classList.add('visible');
    }

    function doSearch() {
      const q = document.getElementById('searchInput').value.trim();
      if (!q || typeof KAKOBUY_DB === 'undefined') return;
      const nq = norm(q);
      const words = nq.split(/\s+/).filter(w => w.length >= 2);
      const best = KAKOBUY_DB
        .map((item, idx) => ({ idx, score: scoreProduct(item, nq, words) }))
        .filter(r => r.score > 0)
        .sort((a, b) => b.score - a.score)[0];
      if (best) { openProduct(best.idx, KAKOBUY_DB[best.idx].category); clearSearch(); }
    }

    function clearSearch() {
      document.getElementById('searchInput').value = '';
      const box = document.getElementById('searchResults');
      box.classList.remove('visible');
      box.innerHTML = '';
    }

    document.addEventListener('click', e => {
      if (!e.target.closest('.search-wrap')) clearSearch();
    });

    /* TOAST */
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    /* COPY */
    function copyCode(code) {
      navigator.clipboard.writeText(code).catch(() => { });
      showToast('✓ Skopiowano: ' + code);
    }

    /* KALKULATOR */
    const RATES = {
      base: { pl: 8, de: 24, uk: 38, us: 58, cn: 48 },
      type: { std: 1, exp: 1.8, eco: 0.7, pal: 3.5 }
    };
    const PROMOS = { WELCOME20: 0.8, BULK15: 0.85, BF30: 0.7, REF10: 0.9, NEWS5: 0.95 };

    function calculate() {
      const from = document.getElementById('from').value;
      const to = document.getElementById('to').value;
      const weight = parseFloat(document.getElementById('weight').value) || 1;
      const type = document.getElementById('type').value;
      const insurance = parseInt(document.getElementById('insurance').value) || 0;
      const cod = parseInt(document.getElementById('cod').value) || 0;
      const promoCode = document.getElementById('promoInput').value.trim().toUpperCase();

      const dest = to === 'pl' ? from : to;
      const base = RATES.base[dest] * RATES.type[type];
      const weightCost = weight * 2.5 * RATES.type[type];
      const subtotal = base + weightCost + insurance + cod;

      let discount = 1, promoLabel = '';
      if (promoCode && PROMOS[promoCode]) { discount = PROMOS[promoCode]; promoLabel = ' (kod: ' + promoCode + ')'; }
      else if (promoCode) { promoLabel = ' (nieprawidłowy kod)'; }

      const total = (subtotal * discount).toFixed(2);
      const savings = promoCode && PROMOS[promoCode] ? (subtotal * (1 - discount)).toFixed(2) : 0;

      document.getElementById('resultPrice').textContent = total + ' zł';
      const typeNames = { std: 'Standardowa', exp: 'Ekspresowa', eco: 'Ekonomiczna', pal: 'Paleta' };
      let bd = `<div class="result-line">Baza: <strong>${base.toFixed(2)} zł</strong></div>
      <div class="result-line">Waga ${weight}kg: <strong>${weightCost.toFixed(2)} zł</strong></div>
      <div class="result-line">Typ: <strong>${typeNames[type]}</strong></div>`;
      if (insurance) bd += `<div class="result-line">Ubezpieczenie: <strong>+${insurance} zł</strong></div>`;
      if (cod) bd += `<div class="result-line">Pobranie: <strong>+${cod} zł</strong></div>`;
      if (savings > 0) bd += `<div class="result-line" style="color:var(--accent)">Oszczędzasz: <strong>-${savings} zł${promoLabel}</strong></div>`;
      else if (promoLabel) bd += `<div class="result-line" style="color:var(--red)">${promoLabel}</div>`;
      document.getElementById('resultBreakdown').innerHTML = bd;
    }

    /* ================================================================
       ITEM FINDER — AI-powered link → product card
       ================================================================ */

    // Input focus style
    const ifInput = document.getElementById('if-url-input');
    if (ifInput) {
      ifInput.addEventListener('focus', () => document.getElementById('if-input-box').classList.add('if-focus'));
      ifInput.addEventListener('blur',  () => document.getElementById('if-input-box').classList.remove('if-focus'));
    }

    let IF_SAVED = []; // session storage

    // ─── Detect source from URL ───────────────────────────────────
    function ifDetectSource(url) {
      if (/taobao\.com|tmall\.com/.test(url)) return { src: 'Taobao', type: 'taobao' };
      if (/weidian\.com/.test(url))           return { src: 'Weidian', type: 'weidian' };
      if (/1688\.com/.test(url))              return { src: '1688', type: '1688' };
      if (/kakobuy\.com/.test(url))           return { src: 'Kakobuy', type: 'kakobuy' };
      if (/pandabuy\.com|pandabuy\.page\.link/.test(url)) return { src: 'Pandabuy', type: 'agent' };
      if (/cnfans\.com/.test(url))            return { src: 'CNFans', type: 'agent' };
      if (/superbuy\.com/.test(url))          return { src: 'Superbuy', type: 'agent' };
      if (/sugargoo\.com/.test(url))          return { src: 'Sugargoo', type: 'agent' };
      if (/cssbuy\.com/.test(url))            return { src: 'CSSBuy', type: 'agent' };
      if (/mulebuy\.com/.test(url))           return { src: 'MuleBuy', type: 'agent' };
      if (/acbuy\.com/.test(url))             return { src: 'ACBuy', type: 'agent' };
      if (/oopbuy\.com/.test(url))            return { src: 'OopBuy', type: 'agent' };
      if (/cnfans|hoobuy|lovegobuy|hipobuy|kameymall|basetao/.test(url)) return { src: 'Agent', type: 'agent' };
      if (/ikako\.vip|sl\.kakobuy\.com/.test(url)) return { src: 'Kakobuy (short)', type: 'kakobuy' };
      if (/m\.tb\.cn/.test(url))              return { src: 'Taobao (mobile)', type: 'taobao' };
      return null;
    }

    function ifUpdateDetect(val) {
      const lbl = document.getElementById('if-detect-label');
      if (!val.trim()) { lbl.textContent = ''; return; }
      const det = ifDetectSource(val);
      if (det) {
        const rawUrl = ifExtractRaw(val);
        const kakobuyLink = ifBuildKakobuyLink(rawUrl);
        lbl.innerHTML = `✓ Wykryto: <span style="color:var(--accent);font-weight:700;">${det.src}</span>
          <br><span style="font-size:10px;color:var(--text3);letter-spacing:0;">🔗 Kakobuy + reflink: </span>
          <a href="${kakobuyLink}" target="_blank"
            style="font-family:'DM Mono',monospace;font-size:10px;color:var(--accent);word-break:break-all;text-decoration:none;"
            title="Otwórz na Kakobuy">${kakobuyLink}</a>
          <button onclick="navigator.clipboard.writeText('${kakobuyLink.replace(/'/g, "\\'")}')
            .then(()=>showToast('✓ Skopiowano link!')).catch(()=>{})"
            style="margin-left:8px;background:rgba(200,245,66,0.12);border:1px solid rgba(200,245,66,0.3);
                   color:var(--accent);font-family:'DM Mono',monospace;font-size:9px;padding:2px 8px;
                   border-radius:4px;cursor:pointer;letter-spacing:1px;">KOPIUJ</button>`;
      } else {
        lbl.innerHTML = `<span style="color:var(--orange);">Nieznane źródło — mimo to spróbuj</span>`;
      }
    }

    // ─── Extract raw marketplace URL from agent wrapper ────────────
    function ifExtractRaw(url) {
      const params = ['url', 'link', 'productLink', 'target', 'itemUrl'];
      let u;
      try { u = new URL(url); } catch(e) { return url; }
      for (const p of params) {
        const v = u.searchParams.get(p);
        if (v) try { return decodeURIComponent(v); } catch(e) { return v; }
      }
      return url;
    }

    // ─── Extract item ID ───────────────────────────────────────────
    function ifExtractItemId(url) {
      let m = url.match(/[?&]id=(\d+)/);
      if (m) return { id: m[1], platform: 'taobao' };
      m = url.match(/itemId=(\d+)/);
      if (m) return { id: m[1], platform: 'weidian' };
      m = url.match(/offer\/(\d+)\.html/);
      if (m) return { id: m[1], platform: '1688' };
      return null;
    }

    // ─── Build kakobuy link (zawsze z reflinklem kdreps) ─────────────
    const KDREPS_AFFCODE = 'kdreps';
    function ifBuildKakobuyLink(rawUrl) {
      if (/kakobuy\.com\/item\/details/.test(rawUrl)) {
        // Już link kakobuy — tylko upewnij się że jest affcode
        try {
          const u = new URL(rawUrl);
          if (!u.searchParams.get('affcode')) u.searchParams.set('affcode', KDREPS_AFFCODE);
          return u.toString();
        } catch(e) { return rawUrl; }
      }
      return 'https://www.kakobuy.com/item/details?url=' + encodeURIComponent(rawUrl) + '&affcode=' + KDREPS_AFFCODE;
    }

    // ─── Main fetch handler ────────────────────────────────────────
    async function ifFetch() {
      const raw = document.getElementById('if-url-input').value.trim();
      if (!raw) { showToast('⚠ Wklej link!'); return; }

      const realUrl = ifExtractRaw(raw);
      const itemInfo = ifExtractItemId(realUrl);
      const kakobuyLink = ifBuildKakobuyLink(realUrl);

      document.getElementById('if-loading').style.display = 'block';
      document.getElementById('if-result').style.display = 'none';
      document.getElementById('if-fetch-btn').disabled = true;
      document.getElementById('if-fetch-btn').style.opacity = '0.6';

      const msgs = [
        'OTWIERANIE KAKOBUY...',
        'ŁADOWANIE STRONY PRODUKTU...',
        'POBIERANIE NAZWY I CENY...',
        'WYDOBYWANIE ZDJĘCIA...',
        'FINALIZACJA DANYCH...'
      ];
      let mi = 0;
      const msgInterval = setInterval(() => {
        document.getElementById('if-loading-msg').textContent = msgs[mi++ % msgs.length];
      }, 900);

      try {
        // 1. Check local DB first
        let productData = null;
        if (typeof KAKOBUY_DB !== 'undefined') {
          const cleanUrl = realUrl.split('?')[0];
          const found = KAKOBUY_DB.find(it => it.link && it.link.includes(cleanUrl) || (it.link && it.link.includes(itemInfo?.id)));
          if (found) {
            productData = {
              name: found.name,
              category: found.category,
              pricePLN: found.pricePLN,
              priceCNY: found.priceCNY,
              quality: found.quality,
              image: found.image,
              confidence: 'high'
            };
          }
        }

        // 2. If not found, try to fetch metadata
        if (!productData) {
          productData = await ifScrapeMetadata(realUrl, itemInfo);
        }

        clearInterval(msgInterval);
        ifRenderResult(productData, kakobuyLink, itemInfo);
      } catch(err) {
        console.error(err);
        clearInterval(msgInterval);
        ifRenderError(kakobuyLink, realUrl);
      }

      document.getElementById('if-loading').style.display = 'none';
      document.getElementById('if-fetch-btn').disabled = false;
      document.getElementById('if-fetch-btn').style.opacity = '1';
    }

    // ─── Check if Scraper API is running (Vercel or Local) ──────────
    async function checkApiStatus() {
      const badge = document.getElementById('api-status-badge');
      const dot = document.getElementById('api-status-dot');
      const text = document.getElementById('api-status-text');
      if (!badge) return;

      // Priority 1: Vercel / Remote API
      // Priority 2: Local Scraper Engine (localhost:5000)
      const healthEndpoints = ['/api/status', 'http://localhost:5000/status'];
      
      for (const url of healthEndpoints) {
        try {
          const res = await fetch(url, { signal: AbortSignal.timeout(2000) });
          if (res.ok) {
            badge.style.background = 'rgba(200,245,66,0.1)';
            badge.style.color = 'var(--accent)';
            badge.style.borderColor = 'rgba(200,245,66,0.3)';
            dot.style.background = 'var(--accent)';
            dot.style.animation = 'pulse 2s infinite';
            text.textContent = url.startsWith('/') ? 'SCRAPER API: CLOUD ONLINE ✓' : 'SCRAPER API: LOCAL ONLINE ✓';
            return;
          }
        } catch(e) {}
      }

      badge.style.background = 'rgba(255,68,68,0.1)';
      badge.style.color = 'var(--red)';
      badge.style.borderColor = 'rgba(255,68,68,0.3)';
      dot.style.background = 'var(--red)';
      dot.style.animation = 'none';
      text.textContent = 'SCRAPER API: OFFLINE';
    }

    // ─── Metadata Scraper (Vercel primary, Local fallback) ──────────
    async function ifScrapeMetadata(url, itemInfo) {
      const platform = itemInfo ? itemInfo.platform : 'unknown';
      let product = {
        name: platform.toUpperCase() + ' ITEM',
        category: 'buty',
        priceCNY: '',
        image: '',
        quality: 'TOP',
        confidence: 'low'
      };

      // Try Vercel Serverless / Remote API first (Automatic)
      // Then fallback to Local Playwright Engine (Manual/Highest Quality)
      const scraperEndpoints = ['/api/scrape', 'http://localhost:5000/scrape'];
      
      for (const apiBase of scraperEndpoints) {
        try {
          console.log(`Trying scraper at ${apiBase}...`);
          const apiUrl = `${apiBase}?url=${encodeURIComponent(url)}`;
          const res = await fetch(apiUrl, { signal: AbortSignal.timeout(30000) });
          if (res.ok) {
            const data = await res.json();
            if (data.status === 'success' || data.name) {
              console.log('✓ SCRAPER SUCCESS:', data);
              product.name = data.name || product.name;
              product.priceCNY = data.priceCNY ? String(data.priceCNY) : '';
              product.image = data.image || '';
              product.confidence = data.source === 'vercel_api' ? 'medium' : 'high';
              return product;
            }
          }
        } catch(e) {
          console.log(`Scraper at ${apiBase} unavailable: ${e.message}`);
        }
      }

      // Final Informational Card
      console.warn('All Scraper APIs offline.');
      product.name = 'Błąd pobierania / Scraper Offline';
      product.confidence = 'low';
      return product;
    }

    // ─── Render result card ────────────────────────────────────────
    function ifRenderResult(product, kakobuyLink, itemInfo) {
      const catNames = {
        'buty': 'OBUWIE', 'koszulki-bluzy': 'ODZIEŻ', 'koszulki-pilkarskie': 'SPORT',
        'spodenki': 'ODZIEŻ', 'spodnie': 'ODZIEŻ', 'sety': 'ODZIEŻ',
        'skarpetki': 'AKCESORIA', 'majtki': 'BIELIZNA', 'paski': 'AKCESORIA',
        'portfele': 'AKCESORIA', 'plecaki': 'AKCESORIA', 'czapki': 'AKCESORIA',
        'kurtki': 'ODZIEŻ', 'perfumy': 'KOSMETYKI'
      };
      const catIcons = {
        'buty':'👟','koszulki-bluzy':'👕','koszulki-pilkarskie':'⚽','spodenki':'🩳',
        'spodnie':'👖','sety':'👔','skarpetki':'🧦','majtki':'🩲','paski':'🥋',
        'portfele':'👛','plecaki':'🎒','czapki':'🧢','kurtki':'🧥','perfumy':'💧'
      };

      const cat = product.category || 'buty';
      const icon = catIcons[cat] || '🛍️';
      const catLabel = catNames[cat] || cat.toUpperCase();

      let imgHtml = '';
      if (product.image) {
        imgHtml = `<img id="if-prod-img" src="${product.image}" alt="${product.name}"
          style="width:100%;height:100%;object-fit:contain;padding:24px;"
          onerror="this.outerHTML='<div class=\\'pd-img-placeholder\\'>${icon}</div>'">`;
      } else if (itemInfo && itemInfo.platform === 'taobao' && itemInfo.id) {
        const proxyImg = `https://img.alicdn.com/bao/uploaded/i1/TB1${itemInfo.id}_!!0-item_pic.jpg_400x400.jpg`;
        imgHtml = `<img id="if-prod-img" src="${proxyImg}" alt="${product.name}"
          style="width:100%;height:100%;object-fit:contain;padding:24px;"
          onerror="this.outerHTML='<div class=\\'pd-img-placeholder\\'>${icon}</div>'">`;
      } else {
        imgHtml = `<div class="pd-img-placeholder">${icon}</div>`;
      }

      const confColor = { high: 'var(--accent)', medium: 'var(--orange)', low: 'var(--text3)' };
      const confLabel = { high: '✓ Wysoka pewność', medium: '~ Średnia pewność', low: '? Niska — zweryfikuj' };
      const conf = product.confidence || 'medium';

      const resultContainer = document.getElementById('if-result-content');
      
      const priceVal = product.priceCNY ? (parseFloat(product.priceCNY) * 0.546).toFixed(2) : '—';

      resultContainer.innerHTML = `
        <div style="background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;animation:fadeUp 0.3s ease;">
          <div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:16px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="width:10px;height:10px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite;flex-shrink:0;"></div>
              <span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;">WYNIK WYSZUKIWANIA</span>
              <span style="font-family:'DM Mono',monospace;font-size:10px;padding:3px 10px;border-radius:20px;background:rgba(200,245,66,0.08);color:${confColor[conf]};border:1px solid ${confColor[conf]}33;">${confLabel[conf]}</span>
            </div>
            <button onclick="ifNewSearch()" style="background:none;border:1px solid var(--border2);color:var(--text3);font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1px;padding:6px 14px;border-radius:6px;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)';this.style.color='var(--text3)'">↩ NOWE SZUKANIE</button>
          </div>

          <div class="pd-grid" style="padding:36px;">
            <div class="pd-img-side">
              <div class="pd-img-frame" style="background:#fff;">${imgHtml}</div>
              <div style="margin-top:12px;text-align:center;">
                <a href="${kakobuyLink}" target="_blank" style="font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);word-break:break-all;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text3)'">🔗 ${kakobuyLink.substring(0, 55)}...</a>
              </div>
            </div>

            <div class="pd-info-side">
              <div class="pd-cat-label">${catLabel}</div>
              <h1 class="pd-name">${product.name || 'PRODUKT'}</h1>
              <div class="pd-divider"></div>

              <div class="pd-prices-row" style="margin-bottom:24px;">
                <div class="pd-price-pln">${priceVal !== '—' ? priceVal + ' zł' : '— zł'}</div>
                <div class="pd-price-cny">${product.priceCNY ? '¥ ' + product.priceCNY : ''}</div>
              </div>

              <div class="pd-badges">
                <div class="pd-badge">JAKOŚĆ: <span>${product.quality || 'TOP'}</span></div>
                ${product.brand ? `<div class="pd-badge">MARKA: <span>${product.brand.toUpperCase()}</span></div>` : ''}
                <div class="pd-badge">ID: <span>${itemInfo ? itemInfo.id : '—'}</span></div>
              </div>

              ${product.description ? `<div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text2);line-height:1.7;padding:16px;background:var(--bg2);border-radius:10px;border:1px solid var(--border);">${product.description}</div>` : ''}

              <div class="pd-divider"></div>

              <a href="${kakobuyLink}" target="_blank" class="pd-buy-btn">🛒 OTWÓRZ NA KAKOBUY</a>

              <button onclick="ifSaveItem(${JSON.stringify(product).replace(/"/g, '&quot;')}, '${kakobuyLink.replace(/'/g, "\\'")}', '${priceVal}')"
                style="width:100%;padding:14px 32px;background:rgba(200,245,66,0.1);color:var(--accent);font-family:'DM Mono',monospace;font-size:12px;font-weight:500;letter-spacing:2px;text-transform:uppercase;border:1px solid rgba(200,245,66,0.3);border-radius:14px;cursor:pointer;transition:all 0.2s;"
                onmouseover="this.style.background='rgba(200,245,66,0.18)'" onmouseout="this.style.background='rgba(200,245,66,0.1)'">
                ＋ ZAPISZ DO BAZY
              </button>

              <p class="pd-note">Dane pobrane automatycznie · Wszystkie prawa zastrzeżone</p>
            </div>
          </div>
        </div>`;

      goTo('item-result');
    }

    // ─── Render error fallback ─────────────────────────────────────
    function ifRenderError(kakobuyLink, rawUrl) {
      const resultContainer = document.getElementById('if-result-content');
      
      resultContainer.innerHTML = `
        <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;padding:32px;text-align:center;animation:fadeUp 0.3s ease;">
          <div style="font-size:40px;margin-bottom:16px;">⚠️</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--text);margin-bottom:8px;">NIE UDAŁO SIĘ POBRAĆ DANYCH</div>
          <div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text3);margin-bottom:24px;">Sprawdź link ręcznie na Kakobuy</div>
          <a href="${kakobuyLink}" target="_blank" class="pd-buy-btn" style="display:inline-flex;max-width:360px;">🛒 OTWÓRZ NA KAKOBUY</a>
          <div style="margin-top:12px;">
            <button onclick="ifNewSearch()" style="background:none;border:1px solid var(--border2);color:var(--text3);font-family:'DM Mono',monospace;font-size:11px;padding:8px 16px;border-radius:8px;cursor:pointer;">↩ SPRÓBUJ PONOWNIE</button>
          </div>
        </div>`;
      
      goTo('item-result');
    }

    // ─── New search ────────────────────────────────────────────────
    function ifNewSearch() {
      document.getElementById('if-url-input').value = '';
      document.getElementById('if-detect-label').textContent = '';
      goTo('item-finder');
      document.getElementById('if-url-input').focus();
    }

    // ─── Save item ─────────────────────────────────────────────────
    function ifSaveItem(product, kakobuyLink, fixedPln) {
      const pln = fixedPln || '';
      const imgEl = document.getElementById('if-prod-img');
      const imgSrc = imgEl && imgEl.complete && imgEl.naturalWidth > 0 ? imgEl.src : '';

      const item = {
        category: product.category || 'buty',
        name: product.name || 'PRODUKT',
        pricePLN: pln,
        priceCNY: product.priceCNY || '',
        quality: product.quality || 'TOP',
        link: kakobuyLink,
        image: imgSrc
      };

      IF_SAVED.push(item);
      ifRenderSaved();
      showToast('✓ Zapisano: ' + item.name);
    }

    // ─── Render saved grid ─────────────────────────────────────────
    function ifRenderSaved() {
      const section = document.getElementById('if-saved-section');
      const grid = document.getElementById('if-saved-grid');
      const count = document.getElementById('if-saved-count');

      if (IF_SAVED.length === 0) { section.style.display = 'none'; return; }
      section.style.display = 'block';
      count.textContent = IF_SAVED.length;

      const catIcons = {
        'buty':'👟','koszulki-bluzy':'👕','koszulki-pilkarskie':'⚽','spodenki':'🩳',
        'spodnie':'👖','sety':'👔','skarpetki':'🧦','majtki':'🩲','paski':'🥋',
        'portfele':'👛','plecaki':'🎒','czapki':'🧢','kurtki':'🧥','perfumy':'💧'
      };

      grid.innerHTML = IF_SAVED.map((item, idx) => {
        const icon = catIcons[item.category] || '🛍️';
        const imgHtml = item.image
          ? `<img src="${item.image}" alt="${item.name}" style="width:100%;height:100%;object-fit:contain;padding:16px;" onerror="this.outerHTML='<div class=\\'no-img-placeholder\\'>${icon}</div>'">`
          : `<div class="no-img-placeholder">${icon}</div>`;
        return `
          <div class="product-card">
            <button onclick="IF_SAVED.splice(${idx},1);ifRenderSaved();" title="Usuń"
              style="position:absolute;top:10px;left:10px;z-index:3;background:rgba(255,68,68,0.85);border:none;color:#fff;width:24px;height:24px;border-radius:50%;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
            <div class="product-img-wrap">${imgHtml}</div>
            <div class="product-card-arrow">→</div>
            <div class="product-info">
              <div class="product-title">${item.name}</div>
              <div class="product-price">
                <span class="pln">${item.pricePLN ? item.pricePLN + ' zł' : '—'}</span>
                <span class="cny">${item.priceCNY ? '¥' + item.priceCNY : ''}</span>
              </div>
              <div class="product-tags">
                ${item.quality ? `<span class="tag-batch">${item.quality}</span>` : ''}
              </div>
            </div>
            ${item.link && item.link !== '#' ? `<a href="${item.link}" target="_blank" style="display:block;margin:0 16px 16px;padding:10px;text-align:center;background:var(--accent);color:#000;font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:1px;border-radius:8px;text-decoration:none;transition:filter 0.2s;" onmouseover="this.style.filter='brightness(1.1)'" onmouseout="this.style.filter=''">🛒 KAKOBUY</a>` : ''}
          </div>`;
      }).join('');
    }

    // ─── Clear saved ───────────────────────────────────────────────
    function ifClearSaved() {
      if (!confirm('Usunąć wszystkie zapisane itemy?')) return;
      IF_SAVED = [];
      ifRenderSaved();
    }

    // ─── Export ────────────────────────────────────────────────────
    function ifExportJS() {
      if (IF_SAVED.length === 0) { showToast('⚠ Brak zapisanych itemów!'); return; }
      const lines = IF_SAVED.map(i => '  ' + JSON.stringify(i)).join(',\n');
      document.getElementById('if-export-text').value =
        `// Wklej poniższe wpisy na końcu tablicy w baza.js (przed ostatnim ];\n// Dodaj przecinek po ostatnim istniejącym wpisie!\n${lines},`;
      document.getElementById('if-export-modal').style.display = 'flex';
    }

    function ifCopyExport() {
      navigator.clipboard.writeText(document.getElementById('if-export-text').value).catch(() => {});
      showToast('✓ Skopiowano!');
    }
  </script>
</body>

</html>